{
  "name": "codex-bridge",
  "version": "0.1.0",
  "description": "MCP bridge that lets ChatGPT Web use local code, test, diff, and change-session tools",
  "homepage": "https://github.com/baochipham942-eng/codex-bridge#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/baochipham942-eng/codex-bridge.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codex-bridge": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node scripts/smoke-mcp.mjs",
    "smoke": "node scripts/smoke-mcp.mjs",
    "smoke:bash": "bash scripts/test-mcp.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "typescript": "5.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
